<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox prefHeight="600.0" prefWidth="900.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="GameController">
  <children>

    <!-- Barre de menus -->
    <MenuBar VBox.vgrow="NEVER">
      <menus>
        <Menu mnemonicParsing="false" text="Fichier">
          <items>
            <MenuItem mnemonicParsing="false" text="Nouvelle partie" onAction="#handleNewGame"/>
            <SeparatorMenuItem mnemonicParsing="false" />
            <MenuItem mnemonicParsing="false" text="Quitter" onAction="#handleQuit"/>
          </items>
        </Menu>
        <Menu mnemonicParsing="false" text="Aide">
          <items>
            <MenuItem mnemonicParsing="false" text="À propos" onAction="#handleAbout"/>
          </items>
        </Menu>
      </menus>
    </MenuBar>

    <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: -fx-background; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;" VBox.vgrow="NEVER">
      <padding><Insets top="8.0" bottom="8.0" left="12.0" right="12.0"/></padding>
      <Label fx:id="labelJoueur"
             text="Tour : Violet"
             style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
      <Label fx:id="labelPhase"
             text="Phase : Pose"
             style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
    </HBox>

    <SplitPane dividerPositions="0.19, 0.78"
               focusTraversable="true"
               VBox.vgrow="ALWAYS">
      <items>

        <!--infos joueurs -->
        <VBox spacing="8.0" minWidth="140.0">
          <padding><Insets top="12.0" left="10.0" right="10.0" bottom="10.0"/></padding>

          <Label text="Joueurs"
                 style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #888888;"/>

          <Label text="● Violet"
                 style="-fx-font-size: 12px; -fx-text-fill: #7F77DD; -fx-font-weight: bold;"/>
          <Label fx:id="labelPosesJ1"  text="Posés : 0 / 9"  style="-fx-font-size: 12px;"/>
          <Label fx:id="labelRestantsJ1" text="Restants : 9" style="-fx-font-size: 12px;"/>
          <Label fx:id="labelPrisJ1"   text="Pris : 0"      style="-fx-font-size: 12px;"/>

          <Pane prefHeight="10.0"/>

          <Label text="● Bleu"
                 style="-fx-font-size: 12px; -fx-text-fill: #378ADD; -fx-font-weight: bold;"/>
          <Label fx:id="labelPosesJ2"  text="Posés : 0 / 9"  style="-fx-font-size: 12px;"/>
          <Label fx:id="labelRestantsJ2" text="Restants : 9" style="-fx-font-size: 12px;"/>
          <Label fx:id="labelPrisJ2"   text="Pris : 0"       style="-fx-font-size: 12px;"/>

          <Pane VBox.vgrow="ALWAYS"/>

          <Label fx:id="labelMessage"
                 text=""
                 wrapText="true"
                 style="-fx-font-size: 12px; -fx-text-fill: #cc4444;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="10.0">
          <padding><Insets top="12.0" left="10.0" right="10.0" bottom="10.0"/></padding>

          <StackPane fx:id="boardPane">
            <Canvas fx:id="boardCanvas" width="340.0" height="340.0"/>
            <Pane fx:id="overlayPane" mouseTransparent="false" pickOnBounds="false"/>
          </StackPane>

          <HBox alignment="CENTER" spacing="8.0" VBox.vgrow="NEVER">
            <TextField fx:id="inputCoup"
                       promptText="Position (ex: 00)"
                       prefWidth="140.0"
                       style="-fx-font-family: monospace;"/>
            <Button fx:id="btnJouer"
                    text="Jouer"
                    defaultButton="true"
                    onAction="#handleCoup"/>
          </HBox>
        </VBox>

        <VBox spacing="8.0" minWidth="150.0">
          <padding><Insets top="12.0" left="10.0" right="10.0" bottom="10.0"/></padding>

          <Label text="Historique"
                 style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #888888;"/>

          <TextArea fx:id="historiqueArea"
                    editable="false"
                    wrapText="true"
                    style="-fx-font-family: monospace; -fx-font-size: 11px;"
                    VBox.vgrow="ALWAYS"/>
        </VBox>

      </items>
    </SplitPane>

    <HBox alignment="CENTER_LEFT" spacing="5.0" VBox.vgrow="NEVER"
          style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0; -fx-background-color: -fx-background;">
      <padding><Insets top="4.0" bottom="4.0" left="8.0" right="8.0"/></padding>
      <Label fx:id="labelStatut"
             text="En attente..."
             HBox.hgrow="ALWAYS"
             style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
      <Pane prefWidth="-1.0" HBox.hgrow="ALWAYS"/>
      <Label fx:id="labelTour"
             text="Tour 0"
             HBox.hgrow="NEVER"
             style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
    </HBox>

  </children>
</VBox>